# ============================================================
# FasalSaathi Backend — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# --- Server ---
PORT=8787
NODE_ENV=development

# --- Supabase ---
# Create a project at https://supabase.com/dashboard
# Settings → API → "Project URL"
SUPABASE_URL=https://your-project-ref.supabase.co

# Settings → API → "anon public" key (safe to use in client)
SUPABASE_ANON_KEY=eyJhbGc...

# Settings → API → "service_role secret" key
# WARNING: This key bypasses Row Level Security. Keep it server-side ONLY.
# Never expose it to the client or commit it to git.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...

# --- Aadhaar Encryption ---
# AES-256-GCM requires a 32-byte key.
# Generate one with: openssl rand -base64 32
# Store the result here. Losing this key = losing all stored Aadhaar ciphertexts.
# COMPLIANCE: Aadhaar Act 2016 + DPDP Act 2025 require this data to be encrypted at rest.
AADHAAR_ENC_KEY=REPLACE_ME_openssl_rand_-base64_32

# --- Google OAuth (used by Supabase Auth) ---
# These are configured in the Supabase dashboard, NOT used directly by this server.
# Documented here so the developer knows they need them:
# Supabase Dashboard → Authentication → Providers → Google
#   - Google Cloud OAuth Client ID
#   - Google Cloud OAuth Client Secret
# Register this callback URL in Google Cloud Console:
#   https://your-project-ref.supabase.co/auth/v1/callback
# (See backend/README.md §2 for full Google OAuth setup steps)

# --- External Data APIs ---
# data.gov.in (Agmarknet daily prices). OPTIONAL — defaults to the PUBLIC SAMPLE
# key below, which is rate-limited and trial-only. Get a real key (free) at
# https://data.gov.in/ → "Register" → API key, for any real usage.
# NOTE: the Agmarknet gateway was returning HTTP 502 as of 2026-06-13; the client
# degrades gracefully (returns "unavailable", never throws) until it recovers.
DATA_GOV_IN_API_KEY=579b464db66ec23bdd000001cdd3946e44ce4aad7209ff7b23ac571b

# Open-Meteo (weather, B5 + the /decision quality-risk modifier): NO KEY REQUIRED.
# CEDA Ashoka (historical monthly prices): host is up; the data endpoint + any
# auth are still being confirmed from its OpenAPI spec — run `npm run check:external`.
# See backend/src/lib/external/ceda.ts.

# --- Future: AI service APIs (separate wave, not yet implemented) ---
# SARVAM_API_KEY=
# OPENROUTER_API_KEY=
