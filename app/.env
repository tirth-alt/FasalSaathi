# FasalSaathi app — Expo public env (EXPO_PUBLIC_* are inlined into the bundle).

# Backend base URL.
# LEAVE THIS UNSET for normal use: the app auto-detects the backend from the Metro
# bundler host (works on web, physical device via Expo Go, and emulators with no
# manual IP). Only set it to force a specific URL, e.g.:
# EXPO_PUBLIC_API_URL=http://192.168.1.42:8787

# Supabase project (publishable key is client-safe). The app authenticates THROUGH
# the backend (phone+password), so these are only needed if you later add
# client-side Supabase (e.g. Google sign-in).
EXPO_PUBLIC_SUPABASE_URL=https://wqeipbirhtjjazmzxqvy.supabase.co
EXPO_PUBLIC_SUPABASE_KEY=sb_publishable_kgbukVqv4ikwS1O6DRsOwQ_dQiSUfSo

# Google Maps JavaScript API key (client-side; used for the draggable farm-pin map).
EXPO_PUBLIC_GOOGLE_MAPS_KEY=AIzaSyCGmtC1L7bAJPXK6Qp6TYhi0b_XtLLaSDU
